// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  password              String?
  image                 String?
  preferredGenres       String                 @default("[]")
  moodPreferences       String                 @default("[]")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  watchlist             Watchlist[]
  ratings               Rating[]
  notifications         Notification[]
  preferences           UserPreference?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Movie {
  id                Int      @id
  title             String
  overview          String?
  posterPath        String?
  backdropPath      String?
  releaseDate       DateTime?
  rating            Float?
  voteCount         Int      @default(0)
  genres            String                 @default("[]")
  originalLanguage  String?
  budget            Int?
  revenue           Int?
  runtime           Int?
  tagline           String?
  status            String?
  popularity        Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  watchlists        Watchlist[]
  ratings           Rating[]
  recommendations   MovieRecommendation[] @relation("movie")
  relatedMovies     MovieRecommendation[] @relation("relatedMovie")
  moodTags          MoodTag[]
}

model MoodTag {
  id        String   @id @default(cuid())
  mood      String
  movieId   Int
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([movieId, mood])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  movieId   Int
  status    String   @default("to_watch") // to_watch, watching, watched
  addedAt   DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  movieId   Int
  rating    Float
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([userId])
  @@index([movieId])
}

model MovieRecommendation {
  id              String   @id @default(cuid())
  movieId         Int
  relatedMovieId  Int
  similarity      Float
  reason          String?
  createdAt       DateTime @default(now())
  
  movie           Movie    @relation("movie", fields: [movieId], references: [id], onDelete: Cascade)
  relatedMovie    Movie    @relation("relatedMovie", fields: [relatedMovieId], references: [id], onDelete: Cascade)

  @@unique([movieId, relatedMovieId])
  @@index([movieId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // movie_released, rating_milestone, etc
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UserPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  theme                 String   @default("dark")
  emailNotifications    Boolean  @default(true)
  discoverNotifications Boolean  @default(true)
  language              String   @default("en")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
